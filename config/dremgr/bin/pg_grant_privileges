#!/bin/bash
# -*- coding: utf-8 mode: sh -*- vim:sw=4:sts=4:et:ai:si:sta:fenc=utf-8

readonly=
defaults=
grant=grant; to=to
args="$(getopt -o rdpK -l readonly,defaults,privileges,revoke -n "$0" -- "$@")" || exit 1
eval "set -- $args"
while [ $# -gt 0 ]; do
    arg="$1"; shift
    case "$arg" in
    --) break;;
    -r|--readonly) readonly=1;;
    -d|--defaults) defaults=1;;
    -p|--privileges) defaults=;;
    -K|--revoke) grant=revoke; to=from;;
    esac
done

read -a users <<<"$FE_USER: ${FE_USERS//
/ }"

read -a user_access <<<"$FE_USER:rw ${FE_ACCESSS//
/ }"

schema="${1:-public}"
for user in "${users[@]}"; do
    user="${user%%:*}"
    access=
    for uaccess in "${user_access[@]}"; do
        if [ "${uaccess%%:*}" == "$user" ]; then
            access="${uaccess#*:}"
            break
        fi
    done
    [ -n "$access" ] || access=read
    case "$access" in
    admin|all|a) access=admin;;
    write|rw|w) [ -n "$readonly" ] && access=read || access=write;;
    read|ro|r|*) access=read;;
    esac

    case "$access" in
    admin)
        schema_grant="all privileges"
        table_grant="all privileges"
        sequence_grant="all privileges"
        ;;
    write)
        schema_grant="usage, create"
        table_grant="select, insert, update, delete, truncate"
        sequence_grant="usage"
        ;;
    read)
        schema_grant="usage"
        table_grant="select"
        sequence_grant="select"
        ;;
    esac
    if [ -n "$defaults" ]; then
        echo "alter default privileges $grant $schema_grant on schemas $to $user;"
        echo "alter default privileges in schema $schema $grant $table_grant on tables $to $user;"
        echo "alter default privileges in schema $schema $grant $sequence_grant on sequences $to $user;"
    else
        echo "$grant $schema_grant on schema $schema $to $user;"
        echo "$grant $table_grant on all tables in schema $schema $to $user;"
        echo "$grant $sequence_grant on all sequences in schema $schema $to $user;"
    fi
done
