# -*- coding: utf-8 mode: sh -*- vim:sw=4:sts=4:et:ai:si:sta:fenc=utf-8

setenv DBNAME=dre
setenv PDBNAME=pdata
setenv DATADIR=var

setenv AUTH_CAS=
setenv CAS_URL=
resetenv CONFIG_ALL_app__cas_url="$CAS_URL"
setenv AUTH_BASIC=
setenv NO_LISTEN=
setenv NO_LSN_DBINST=
setenv NO_LSN_DBFRONT=
setenv NO_LSN_WEBFRONT=
setenv WEBFRONT_URL=

setenv POSTGRES_USER=postgres
setenv POSTGRES_PASSWORD=

resetenv PGUSER="$POSTGRES_USER"
resetenv PGDATABASE="$DBNAME"

setenv FE_USER=dreadmin
setenv FE_PASSWORD=
setenv FE_USERS=
setenv FE_ACCESS=

resetenv PGBOUNCER_ADMIN_USER=pgbouncer
setenv PGBOUNCER_ADMIN_PASS=
setenv __ALL__PGBOUNCER_DBS="$DBNAME $PDBNAME"
setenv PGBOUNCER_USERS="${FE_USER}:${FE_PASSWORD} ${FE_USERS}"

setenv PGADMIN_USER="$FE_USER"
setenv PGADMIN_PASSWORD="$FE_PASSWORD"

setenv ADMINER_USER="$FE_USER"
setenv ADMINER_PASSWORD="$FE_PASSWORD"
setenv ADMINER_DB="$DBNAME"

setenv APP_PROFILES=
setenv APP_PROFILES_AUTO=
resetenv POSTGRES_PROFILES="$APP_PROFILES"

setenv APP_PROFILE=
setenv POSTGRES_PROFILE="$APP_PROFILE"
setenv APP_DATADIR=

profile_vars=(
    DRE_URL=
    DRE_USER=
    DRE_PASSWORD=
    DRE_PREFIX=
    DRE_FILES_FROM=
    POSTGRES_HOST=
    POSTGRES_USER=
    POSTGRES_PASSWORD=
    INST_VIP=
    INST_PORT=
    FE_HOST=
    FE_PORT=
    FE_DBNAME=
    FE_USER=
    FE_PASSWORD=
    FE_USERS=
    PGADMIN_USER=
    PGADMIN_PASSWORD=
    ADMINER_DBHOSTS=
    ADMINER_DBCONNS=
    ADDON_URLS=
    CRON_PLAN=
    CRON_DISABLE=
    CRON_MAX_AGE=
    HOST_MAPPINGS=
    NOTIF_TIMEOUT=30s
    NOTIF_TIMEOUT_KILL=30s
    MINIMIZE_DOWNTIME=1
    V29FIX_DY=
    VxxFIX_FC=
    VxxTECH=auto
)
APP_PROFILE_VARS=
for profile_var in "${profile_vars[@]}"; do
    setenv "$profile_var"
    APP_PROFILE_VARS="$APP_PROFILE_VARS${APP_PROFILE_VARS:+ }${profile_var%%=*}"
done
resetenv APP_PROFILE_VARS="$APP_PROFILE_VARS"
unset profile_vars profile_var

setenv EXPECTED_FILES="
v32:
schema_tech.bin
chc.bin idt.bin ins.bin keycloak.bin coc.bin odf.bin pai.bin ref.bin piece.bin
piste_inscription-dossiers_inscription.json.gz
piste_inscription-paiements.json.gz
piste_inscription-calendrier.json.gz
piste_inscription-chemins.json.gz
"
